import yfinance as yf
import requests
import os
from datetime import datetime
from dotenv import load_dotenv
import sys

load_dotenv()

OPENROUTER_KEY = os.getenv("OPENROUTER_API_KEY")
TELEGRAM_TOKEN = os.getenv("TELEGRAM_TOKEN")
CHAT_ID = os.getenv("CHAT_ID")

# Sua carteira oficial
CARTEIRA = {
    "🏢 AÇÕES BRASILEIRAS": ["SAPR4.SA", "VIVT3.SA", "TAEE11.SA", "BBSE3.SA", "ITSA4.SA", "VALE3.SA", "ISAE4.SA", "BBAS3.SA"],
    "🏘️ FIIs e FIAGROS": ["MXRF11.SA", "VISC11.SA", "BTHF11.SA", "HGLG11.SA", "KNRI11.SA", "VINO11.SA", "SNAG11.SA"],
    "🌎 INTERNACIONAL": ["IVV", "MCD"],
    "🪙 CRIPTOMOEDAS": ["BTC-USD", "ETH-USD"]
}

def processar_dados_e_lista(periodo_ia):
    print(f"🔍 Coletando dados (IA: {periodo_ia} | Lista: 1d)...")
    lista_visual = ""
    dados_para_ia = ""
    
    for categoria, ativos in CARTEIRA.items():
        lista_visual += f"\n*{categoria}*\n"
        for ticker_nome in ativos:
            try:
                t = yf.Ticker(ticker_nome)
                # Para a lista visual, queremos sempre o último dia disponível
                hist_lista = t.history(period="2d") 
                if hist_lista.empty: continue
                
                # Para a IA, pegamos o período do relatório (1d, 5d ou 30d)
                hist_ia = t.history(period=periodo_ia)
                
                # Dados da lista (Hoje vs Ontem)
                fechamento = hist_lista['Close'].iloc[-1]
                abertura = hist_lista['Open'].iloc[-1]
                variacao = ((fechamento / abertura) - 1) * 100
                
                # Dados da IA (Variação do período total)
                var_ia = ((hist_ia['Close'].iloc[-1] / hist_ia['Close'].iloc[0]) - 1) * 100
                
                emoji = "🟩" if variacao > 0.05 else "🟥" if variacao < -0.05 else "⬜"
                t_limpo = ticker_nome.replace(".SA", "")
                simbolo = "$" if "INTERNACIONAL" in categoria or "CRIPTO" in categoria else "R$"
                
                # Montando a string final da lista
                lista_visual += f"{emoji} {t_limpo}: {simbolo} {fechamento:.2f} ({variacao:+.2f}%)\n"
                dados_para_ia += f"{t_limpo}: {var_ia:+.2f}% | "
                
            except Exception as e:
                print(f"⚠️ Erro no ativo {ticker_nome}: {e}")
                continue
    return lista_visual, dados_para_ia

def gerar_insight_ia(dados, tipo):
    if not dados: return "Sem dados suficientes para análise."
    
    url = "https://openrouter.ai/api/v1/chat/completions"
    config = {
        "DIARIO": "Resumo diário de 3 linhas. Seja direto e use emojis.",
        "SEMANAL": "Análise de tendência semanal (5 dias). Destaque 2 ativos. Mínimo 6 linhas.",
        "MENSAL": "Análise macro profunda (30 dias). Fale de juros e setores. Mínimo 12 linhas."
    }
    
    prompt = f"Aja como um Gestor de Fundo. {config[tipo]} Analise estes dados: {dados}"
    
    payload = {
        "model": "google/gemini-2.0-flash-001",
        "messages": [{"role": "system", "content": prompt}],
        "temperature": 0.4
    }
    
    res = requests.post(url, headers={"Authorization": f"Bearer {OPENROUTER_KEY}"}, json=payload)
    return res.json()['choices'][0]['message']['content'] if res.status_code == 200 else "Insight indisponível."

def main():
    agora = datetime.now()
    
    # LÓGICA DE TESTE: Verifica se você passou um argumento no terminal
    if len(sys.argv) > 1:
        tipo = sys.argv[1].upper() # Pega o que você digitou (MENSAL ou SEMANAL)
    else:
        # Lógica automática original
        if agora.day == 1: tipo = "MENSAL"
        elif agora.weekday() == 4: tipo = "SEMANAL"
        else: tipo = "DIARIO"

    # Define o período da IA com base no tipo escolhido
    periodo_map = {"MENSAL": "30d", "SEMANAL": "5d", "DIARIO": "1d"}
    p_ia = periodo_map.get(tipo, "1d")

    # O resto do código continua igual...
    cabecalho = f"📊 *PERFORMANCE - {agora.strftime('%B / %Y').upper()}*\n"
    cabecalho += f"🗓️ _Gerado em: {agora.strftime('%d/%m/%Y às %H:%M')} (MODO TESTE: {tipo})_\n\n"

    lista_corpo, dados_ia = processar_dados_e_lista(p_ia)
    resumo_ia = gerar_insight_ia(dados_ia, tipo)
    
    mensagem_final = f"{cabecalho}📝 *RESUMO {tipo}*\n{resumo_ia}\n{lista_corpo}"
    
    requests.post(f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage", 
                  json={"chat_id": CHAT_ID, "text": mensagem_final, "parse_mode": "Markdown"})
    print(f"🚀 Relatório de TESTE {tipo} enviado!")

if __name__ == "__main__":
    main()